    <!-- Math Logic Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const leadsSlider = document.getElementById('leads');
            const profitSlider = document.getElementById('profit');
            
            const leadsVal = document.getElementById('leads-val');
            const profitVal = document.getElementById('profit-val');
            
            const monthlyDisplay = document.getElementById('monthly-recovery');
            const annualDisplay = document.getElementById('annual-recovery');
            const dynamicBurnText = document.getElementById('dynamic-burn-text');

            function updateMath() {
                // Get values
                const leads = parseInt(leadsSlider.value);
                const profit = parseInt(profitSlider.value);
                
                // Update UI Labels
                leadsVal.innerText = leads;
                profitVal.innerText = 'R ' + profit.toLocaleString();
                
                // The Business Logic
                // 1. Calculate 40% rejection rate
                const totalRejects = Math.round(leads * 0.40);
                // 2. Calculate 15% recovery on those rejects
                const unitsRecovered = Math.round(totalRejects * 0.15); 
                // 3. Calculate Monthly and Annual GP impact
                const monthlyValue = unitsRecovered * profit;
                const annualValue = monthlyValue * 12;

                // Update UI Outputs
                monthlyDisplay.innerText = 'R ' + monthlyValue.toLocaleString();
                annualDisplay.innerText = 'R ' + annualValue.toLocaleString();
                
                // Update Dynamic "Burning" Statement
                dynamicBurnText.innerText = `By doing nothing, that dealership is effectively "burning" R${monthlyValue.toLocaleString()} in pure profit every month.`;
            }

            // Listeners
            leadsSlider.addEventListener('input', updateMath);
            profitSlider.addEventListener('input', updateMath);
            
            // Initialize on load
            updateMath();
        });
    </script>
