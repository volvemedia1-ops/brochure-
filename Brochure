        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600;700;800;900&display=swap');
        
        body { 
            font-family: 'Inter', sans-serif; 
            -webkit-font-smoothing: antialiased;
        }

        /* Custom Variables */
        :root {
            --cbf-navy: #1A365D; --cbf-purple: #7C3AED; --cbf-white: #FFFFFF;
            --cbf-light: #F8FAFC; --cbf-green: #10B981; --cbf-dark-bg: #0F172A;
        }
        
        .gradient-bg { 
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); 
        }
        
        .calculator-card { 
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1); 
        }
        
        /* SLIDER STYLES */
        .cbf-slider-section { width: 100%; padding: 80px 0; background: #fff; overflow: hidden; border-top: 1px solid #f1f5f9; }
        .cbf-slider-header { text-align: center; margin-bottom: 50px; padding: 0 20px; }
        .cbf-slider-header h2 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2rem; color: #1e293b; margin-bottom: 10px; font-weight: 700; }
        .cbf-slider-header p { color: #64748b; font-size: 1.1rem; }
        
        .cbf-slider-track { display: flex; gap: 40px; animation: cbf-scroll 30s linear infinite; width: max-content; padding-left: 40px; }
        .cbf-slider-track:hover { animation-play-state: paused; }
        
        @keyframes cbf-scroll { 
            0% { transform: translateX(0); } 
            100% { transform: translateX(-50%); } 
        }

        .cbf-logo-card {
            background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px;
            width: 200px; height: 130px; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            opacity: 0.6; filter: grayscale(100%);
        }
        .cbf-logo-card:hover { transform: scale(1.05); opacity: 1; filter: grayscale(0%); box-shadow: 0 10px 25px rgba(0,0,0,0.1); border-color: var(--cbf-purple); }
        .cbf-logo-card img { max-width: 80%; max-height: 80%; object-fit: contain; }

        /* FOOTER STYLES */
        .cbf-footer-wrapper { position: relative; margin-top: 0; width: 100%; font-family: 'Inter', sans-serif; }
        .cbf-wave-divider { position: absolute; top: -100px; left: 0; width: 100%; height: 101px; line-height: 0; z-index: 1; }
        .cbf-wave-divider svg { position: relative; display: block; width: calc(100% + 1.3px); height: 100px; }
        .cbf-footer-new { background: linear-gradient(to bottom, #1A365D 0%, #0F172A 100%); color: white; padding: 40px 20px 60px 20px; position: relative; z-index: 2; }
        .cbf-footer-inner { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 50px; max-width: 1200px; margin: 0 auto; }
        .cbf-footer-col h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.5rem; margin-bottom: 25px; position: relative; display: inline-block; }
        .cbf-footer-col h3::after { content: ''; display: block; width: 40px; height: 3px; background: var(--cbf-purple); margin-top: 8px; border-radius: 2px; }
        .cbf-footer-link { color: #cbd5e1; display: block; margin-bottom: 12px; transition: all 0.3s ease; position: relative; text-decoration: none; }
        .cbf-footer-link:hover { color: white; padding-left: 10px; }
        .cbf-footer-link:hover::before { content: '›'; position: absolute; left: -10px; color: var(--cbf-purple); font-weight: bold; }
        .cbf-social-container { display: flex; gap: 15px; }
        .cbf-social-btn { width: 45px; height: 45px; border-radius: 50%; background: rgba(255, 255, 255, 0.1); display: flex; align-items: center; justify-content: center; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); color: white; border: 1px solid transparent; }
        .cbf-social-btn svg { width: 22px; height: 22px; fill: currentColor; }
        .cbf-social-btn:hover { background: var(--cbf-purple); transform: scale(1.1) rotate(5deg); border-color: rgba(255,255,255,0.2); box-shadow: 0 0 15px rgba(124, 58, 237, 0.6); }

        /* Custom Slider Styling */
        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            background: transparent;
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 24px;
            width: 24px;
            border-radius: 50%;
            background: #2563eb;
            cursor: pointer;
            margin-top: -8px;
            box-shadow: 0 2px 6px rgba(37, 99, 235, 0.4);
            border: 4px solid #fff;
        }
        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 8px;
            cursor: pointer;
            background: #e2e8f0;
            border-radius: 4px;
        }
        input[type=range]:focus {
            outline: none;
        }
    </style>
